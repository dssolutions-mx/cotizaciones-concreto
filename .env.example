# FIFO auto-allocation HTTP endpoint (GET /api/cron/fifo-auto-allocate).
# Schedule ONLY via Supabase (pg_cron → Edge Function or pg_net HTTP → this URL), never Vercel Cron — see .cursor/rules/cron-jobs-supabase-only.mdc
# Same secret pattern as other crons: Authorization: Bearer <secret>
# FIFO_CRON_SECRET= # optional; falls back to CRON_SECRET
# CRON_SECRET=
# user_profiles.id used as material_consumption_allocations.created_by (e.g. system / executive)
# FIFO_ALLOCATION_ACTOR_USER_ID=
# FIFO_CRON_MIN_AGE_HOURS=48
# FIFO_CRON_MAX_REMISIONES=100

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
# Optional: plant financial dashboard source — 'fifo' uses vw_plant_financial_analysis_unified_fifo (lot/FIFO costs); omit or 'list' for list prices.
# NEXT_PUBLIC_PLANT_FINANCIAL_UNIFIED_SOURCE=list
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: For backfill-product-prices script (bypasses auth when header matches)
# BACKFILL_SECRET=your-random-secret

# Compliance cross-check (mantenimiento + cotizador)
# MANTENIMIENTO_SUPABASE_URL=https://txapndpstzcspgxlybll.supabase.co
# MANTENIMIENTO_SUPABASE_SERVICE_ROLE_KEY=
# COMPLIANCE_CRON_SECRET=random-long-secret
# COMPLIANCE_DIGEST_RECIPIENTS=ops@dcconcretos.com.mx
# Overrides también editables en /production-control/daily-compliance (tabla compliance_plant_email_overrides).
# COMPLIANCE_OVERRIDES_JSON={"P001":{"dosificador":"dosificacion@dcconcretos.com.mx"},"P002":{"dosificador":"dosificacion2@dcconcretos.com.mx","jefe_planta":"dosificacion2@dcconcretos.com.mx"},"P004P":{"dosificador":"planta4@dcconcretos.com.mx"},"P005":{"dosificador":"Laboratoriotijuana@dcconcretos.com.mx"}}
# COMPLIANCE_FROM_EMAIL=juan.aguirre@dssolutions-mx.com
# SENDGRID_API_KEY=
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app