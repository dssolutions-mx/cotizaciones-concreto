# =============================================================================
# Environment variables — cotizaciones-concreto (Next.js)
# =============================================================================
#
# Setup:
#   cp .env.example .env.local
#   Fill values from Supabase → Project Settings → API (URL, anon, service_role).
#
# Legend:
#   [required]  — app auth/data breaks without it
#   [dev]       — strongly recommended for local development
#   [optional]  — feature-specific; safe to leave empty
#   [scripts]   — used by scripts/ only (not loaded by `npm run dev` unless exported)
#   [edge]      — Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets)
#
# Never commit .env.local (gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# [required] Supabase — main project (cotizador)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# [dev] URLs — avoid production redirects in emails and approval links
# -----------------------------------------------------------------------------
# Public site origin (geocode backfill, some server calls). Defaults to http://localhost:3000 in places.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# App origin for invites, password reset, credit/quote/governance links. Falls back to https://dcconcretos-hub.com if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# [optional] JWT signing for email action tokens (quote/credit/governance)
# Supabase Dashboard → Project Settings → API → JWT Secret
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset (works locally; prefer JWT secret in prod).
# -----------------------------------------------------------------------------
# SUPABASE_JWT_SECRET=
# JWT_SECRET=

# -----------------------------------------------------------------------------
# [optional] Google Maps — quotes, maps UI, geocode API routes
# Browser: NEXT_PUBLIC_* ; server routes also accept GOOGLE_MAPS_API_KEY
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# [optional] Finanzas — plant financial dashboard cost source
# Omit or "list" = list prices; "fifo" = vw_plant_financial_analysis_unified_fifo
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PLANT_FINANCIAL_UNIFIED_SOURCE=list

# -----------------------------------------------------------------------------
# [optional] Email (SendGrid) — invites, password reset, compliance digest, transfers
# -----------------------------------------------------------------------------
# SENDGRID_API_KEY=
# NOTIFICATION_FROM_EMAIL=
# INTER_PLANT_TRANSFER_NOTIFY_EMAIL=
# COMPLIANCE_FROM_EMAIL=
# COMPLIANCE_FROM_NAME=

# -----------------------------------------------------------------------------
# [optional] Compliance cross-check (mantenimiento DB + daily digest)
# Overrides also editable in /production-control/daily-compliance (BD).
# See docs/COMPLIANCE_DAILY.md
# -----------------------------------------------------------------------------
# MANTENIMIENTO_SUPABASE_URL=
# MANTENIMIENTO_SUPABASE_SERVICE_ROLE_KEY=
# COMPLIANCE_CRON_SECRET=
# COMPLIANCE_DIGEST_RECIPIENTS=
# COMPLIANCE_OVERRIDES_JSON={"P001":{"dosificador":"dosificacion@dcconcretos.com.mx"}}
# Cron auth fallback shared with FIFO endpoint (Bearer token):
# CRON_SECRET=

# -----------------------------------------------------------------------------
# [optional] FIFO auto-allocation cron — GET /api/cron/fifo-auto-allocate
# Schedule via Supabase (pg_cron → Edge / pg_net), not Vercel Cron.
# See .cursor/rules/cron-jobs-supabase-only.mdc
# -----------------------------------------------------------------------------
# FIFO_CRON_SECRET=
# FIFO_ALLOCATION_ACTOR_USER_ID=
# FIFO_CRON_MIN_AGE_HOURS=48
# FIFO_CRON_MAX_REMISIONES=100

# -----------------------------------------------------------------------------
# [optional] Backfill / maintenance API
# -----------------------------------------------------------------------------
# BACKFILL_SECRET=

# -----------------------------------------------------------------------------
# [optional] Debug UI (development)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ARKIK_DEBUG=true
# NEXT_PUBLIC_SHOW_VENTAS_DEBUG=true

# -----------------------------------------------------------------------------
# [optional] Feature flags — legacy env names (UI may still mention them).
# Runtime flags live in src/config/featureFlags.ts (currently hardcoded on).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_MASTER_GROUPING=true
# NEXT_PUBLIC_FEATURE_MASTER_PRICING=true

# =============================================================================
# [scripts] Operational scripts (scripts/*.ts) — copy into .env.local only when running them
# =============================================================================

# --- FIFO backfill / reports ---
# FIFO_BACKFILL_FROM=
# FIFO_BACKFILL_TO=
# FIFO_BACKFILL_REMISION_IDS=
# FIFO_BACKFILL_RETRY_ONCE=
# FIFO_BACKFILL_EXIT_ZERO=
# FIFO_DATE_FROM=
# FIFO_DATE_TO=
# FIFO_PLANT_ID=
# FIFO_TIPO_REMISION=CONCRETO
# FIFO_INCLUDE_ALLOCATED=
# FIFO_STATUSES=pending,partial,error
# FIFO_FIRST_SKIP_CSV=
# FIFO_RESET_ALLOCATIONS_BEFORE_BACKFILL=
# FIFO_RUN_OUT_DIR=
# FIFO_GAP_FROM=
# FIFO_GAP_TO=
# FIFO_GAP_OUT=
# FIFO_GAP_TRIAGE_OUT=
# FIFO_DIAG_DEMAND_FROM=

# --- One-off imports / HYCSA ---
# WATER_IMPORT_PLANT_ID=
# WATER_IMPORT_MATERIAL_ID=
# WATER_IMPORT_SUPPLIER_ID=
# WATER_IMPORT_ENTERED_BY=
# WATER_IMPORT_CSV=
# WATER_IMPORT_DRY_RUN=true
# HYCSA_QUOTE_ACTOR_USER_ID=
# PITAHAYA_ONLY=1

# =============================================================================
# [edge] Supabase Edge Function secrets (NOT read from .env.local by default)
# Configure in Supabase Dashboard → Edge Functions → Secrets for deployed functions.
# Mirror local .env.local values where names match.
# =============================================================================
#
# SUPABASE_URL                    (often auto-injected; same host as NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY
# SENDGRID_API_KEY
# FRONTEND_URL                    (≈ NEXT_PUBLIC_APP_URL)
# APP_URL                         (≈ NEXT_PUBLIC_APP_URL; used by daily-compliance-check)
# SUPABASE_JWT_SECRET / JWT_SECRET
# NOTIFICATION_FROM_EMAIL
# EMA_FROM_EMAIL
# COMPLIANCE_CRON_SECRET
#
# =============================================================================
